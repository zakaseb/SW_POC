# ---------------------------------------------------------------------------
# SW_POC configuration. Copy to .env and adjust. Never commit a real .env.
# Docker Compose auto-loads this file from the project root.
# ---------------------------------------------------------------------------

# --- Ollama ---------------------------------------------------------------
# In Docker: host.docker.internal reaches Ollama running on the host.
# Running natively (no Docker): use http://127.0.0.1:11434
# The host daemon MUST be started with OLLAMA_HOST=0.0.0.0 or it will refuse
# connections from the Docker bridge.
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_LLM_NAME=qwen2.5:14b-instruct
OLLAMA_EMBEDDING_MODEL_NAME=nomic-embed-text:latest
OLLAMA_NUM_CTX=8192

# --- FastAPI wrapper ------------------------------------------------------
# In Docker: http://api:8000 (the compose service name).
# Running natively: http://127.0.0.1:8000
RAG_API_BASE=http://api:8000
USE_API_WRAPPER=true
RAG_API_KEY=

# --- Hugging Face / offline mode -----------------------------------------
# MODEL_CACHE_DIR must match the volume mount in docker-compose.yml.
# HF_LOCAL_FILES_ONLY=true blocks all runtime HF network calls; populate the
# cache first with `python pre_download_model.py`.
MODEL_CACHE_DIR=./models
HF_LOCAL_FILES_ONLY=true
RERANKER_MODEL_NAME=cross-encoder/ms-marco-MiniLM-L-6-v2
TOKENIZER_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2

# --- Storage --------------------------------------------------------------
BASE_STORE=./document_store

# --- Logging / debug ------------------------------------------------------
LOG_LEVEL=INFO
# Set only when capturing wrapper -> Ollama traffic in Postman:
# POSTMAN_PROXY=http://127.0.0.1:5560

# --- Docker runtime -------------------------------------------------------
# Must match your host user (run `id -u` / `id -g`) so bind-mounted
# document_store/ and models/ stay writable.
UID=1000
GID=1000

HOME=/tmp
STREAMLIT_BROWSER_GATHER_USAGE_STATS=false